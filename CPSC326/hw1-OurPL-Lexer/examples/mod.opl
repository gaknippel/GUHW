fun truncate(n) {
    var i = 0;
    if (n >= 0) 
    {
        while (i + 1 <= n) 
        {
            i = i + 1;
        }
    } 
    else 
    {
        while (i - 1 >= n) 
        {
            i = i - 1;
        }
    }
    return i;
}

fun mod(a, b) {
    return a - (b * truncate(a / b));
}

print mod(21,5);
print mod(-21,5);
print mod(-21,-5);
print mod(21,-5);
